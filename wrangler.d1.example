# Add this to your wrangler.toml or wrangler.jsonc file:

# Auth Database (Better Auth tables: users, sessions, accounts, organizations, members, etc.)
[[d1_databases]]
binding = "AUTH_DB"
database_name = "your-app-auth"
database_id = "your-auth-database-id"
migrations_dir = "quickback/drizzle/auth"

# Features Database (application tables)
[[d1_databases]]
binding = "DB"
database_name = "your-app-features"
database_id = "your-features-database-id"
migrations_dir = "quickback/drizzle/features"

# Security Audit Database (unsafe cross-tenant action logs)
[[d1_databases]]
binding = "AUDIT_DB"
database_name = "your-app-audit"
database_id = "your-audit-database-id"
migrations_dir = "quickback/drizzle/audit"

# Webhooks Database (webhook events, endpoints, deliveries)
[[d1_databases]]
binding = "WEBHOOKS_DB"
database_name = "your-app-webhooks"
database_id = "your-webhooks-database-id"
migrations_dir = "quickback/drizzle/webhooks"

# Webhook processing queue (inbound + outbound)
[[queues.producers]]
binding = "WEBHOOKS_QUEUE"
queue = "your-app-webhooks-queue"

[[queues.consumers]]
queue = "your-app-webhooks-queue"
max_batch_size = 10
max_batch_timeout = 30
max_retries = 3
dead_letter_queue = "your-app-webhooks-dlq"

# Dead letter queue for failed webhooks
[[queues.consumers]]
queue = "your-app-webhooks-dlq"
max_batch_size = 1
