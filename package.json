{
  "name": "recruitment-example",
  "version": "0.1.0",
  "scripts": {
    "dev": "wrangler dev",
    "build": "tsc",
    "db:migrate:auth:local": "wrangler d1 migrations apply recruitment-example-auth --local",
    "db:migrate:auth:remote": "wrangler d1 migrations apply recruitment-example-auth --remote",
    "db:migrate:features:local": "wrangler d1 migrations apply recruitment-example-features --local",
    "db:migrate:features:remote": "wrangler d1 migrations apply recruitment-example-features --remote",
    "db:migrate:webhooks:local": "wrangler d1 migrations apply recruitment-example-webhooks --local",
    "db:migrate:webhooks:remote": "wrangler d1 migrations apply recruitment-example-webhooks --remote",
    "db:migrate:local": "npm run db:migrate:auth:local && npm run db:migrate:features:local && npm run db:migrate:webhooks:local",
    "db:migrate:remote": "npm run db:migrate:auth:remote && npm run db:migrate:features:remote && npm run db:migrate:webhooks:remote",
    "deploy": "npm run db:migrate:remote && wrangler deploy",
    "db:migrate:audit:local": "wrangler d1 migrations apply recruitment-example-audit --local",
    "db:migrate:audit:remote": "wrangler d1 migrations apply recruitment-example-audit --remote"
  },
  "dependencies": {
    "hono": "^4.12.14",
    "zod": "^4.3.6",
    "drizzle-orm": "^0.45.2",
    "better-auth": "^1.5.0",
    "@better-auth/drizzle-adapter": "^1.5.0",
    "@better-auth/api-key": "^1.5.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "drizzle-kit": "^0.31.10",
    "@cloudflare/workers-types": "^4.20260417.1",
    "wrangler": "^4.83.0"
  },
  "peerDependencies": {},
  "optionalDependencies": {},
  "engines": {}
}